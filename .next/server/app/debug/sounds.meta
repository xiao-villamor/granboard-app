{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/debug/layout,_N_T_/debug/sounds/layout,_N_T_/debug/sounds/page,_N_T_/debug/sounds"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/debug/sounds/__PAGE__",
    "/debug/sounds",
    "/debug",
    "/_index"
  ]
}