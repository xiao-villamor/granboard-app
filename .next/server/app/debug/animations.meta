{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/debug/layout,_N_T_/debug/animations/layout,_N_T_/debug/animations/page,_N_T_/debug/animations"
  },
  "segmentPaths": [
