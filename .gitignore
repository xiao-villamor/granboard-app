# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.pnpm-store/
.pnpm-debug.log

# testing
/coverage
*.lcov
/test-results/
/playwright-report/
/playwright/.cache/

# astro
/dist/
.astro/

# production
/build

# misc
.DS_Store
*.pem
CLAUDE.md
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# local env files
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# typescript
*.tsbuildinfo

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IDE - JetBrains
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# System Files
Thumbs.db
.cache
.temp
*.swp
*.swo
*~

# Package manager lock files
# Root uses pnpm — ignore npm/yarn lockfiles at root level only
/package-lock.json
yarn.lock
# Keep pnpm-lock.yaml in git (recommended for pnpm)
# Keep server/package-lock.json — server uses npm, lockfile needed for Docker build
