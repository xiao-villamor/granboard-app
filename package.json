{
  "name": "granboard-app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 8080",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "concurrently -n astro,ws -c blue,green \"pnpm dev\" \"pnpm dev:server\"",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "build": "astro build",
    "build:server": "npm --prefix server run build",
    "build:all": "pnpm build && pnpm build:server",
    "preview": "astro preview --port 8080",
    "start": "node dist/server/entry.mjs",
    "check": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/node": "^9.1.3",
    "@astrojs/svelte": "^7.0.8",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/manrope": "^5.2.5",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "astro": "^5.8.1",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "svelte": "^5.34.7",
    "svelte-fa": "^4.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/web-bluetooth": "^0.0.21",
    "concurrently": "^9.2.1",
    "svelte-check": "^4.2.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
