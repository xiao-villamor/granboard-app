{
  "name": "granboard-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation --no-warnings\" next dev -p 8080",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "concurrently -n next,ws -c blue,green \"pnpm dev\" \"pnpm dev:server\"",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --no-warnings\" next build",
    "build:server": "npm --prefix server run build",
    "build:all": "pnpm build && pnpm build:server",
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation --no-warnings\" next start -p 8080",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "next": "^16.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/web-bluetooth": "^0.0.21",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "^5"
  }
}
